<div class="container-fluid">
  <div class="header-section">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-12 text-center">
          <h1 class="display-4 text-white mb-4">
            <i class="fas fa-gamepad"></i>
            Bộ Công Cụ Kho Đồ Valorant
          </h1>
          <p class="lead text-white-50">Tạo ảnh chụp màn hình kho đồ và thông tin tài khoản Valorant của bạn</p>
        </div>
      </div>
    </div>
  </div>

  <div class="main-content">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          
          <!-- Input Section -->
          <div class="card bg-dark border-secondary mb-4">
            <div class="card-header bg-primary text-white">
              <h5 class="mb-0">
                <i class="fas fa-key"></i>
                Nhập Mã Access Token
              </h5>
            </div>
            <div class="card-body">
              <form id="tokenForm">
                <div class="mb-3">
                  <label for="accessToken" class="form-label text-white">Mã Access Token Riot</label>
                  <textarea 
                    class="form-control bg-secondary text-white border-dark" 
                    id="accessToken" 
                    rows="3" 
                    placeholder="Nhập mã access token Riot Games của bạn vào đây..."
                    required></textarea>
                  <div class="form-text text-muted">
                    <i class="fas fa-info-circle"></i>
                    Access token của bạn được xử lý an toàn và không lưu trữ trên máy chủ của chúng tôi
                  </div>
                </div>
                <div class="d-grid">
                  <button type="submit" class="btn btn-success btn-lg" id="generateBtn">
                    <i class="fas fa-camera"></i>
                    Tạo Ảnh Chụp Màn Hình
                  </button>
                </div>
              </form>
            </div>
          </div>

          <!-- Loading Section -->
          <div id="loadingSection" class="card bg-dark border-secondary mb-4" style="display: none;">
            <div class="card-body text-center">
              <div class="spinner-border text-primary mb-3" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <h5 class="text-white">Đang xử lý...</h5>
              <p class="text-muted">Đang chụp ảnh màn hình kho đồ của bạn. Quá trình này có thể mất vài phút.</p>
              <div class="progress mt-3">
                <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" 
                     role="progressbar" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <!-- Results Section -->
          <div id="resultsSection" style="display: none;">
            
            <!-- Download Button -->
            <div class="text-center mb-4">
              <button id="downloadAllBtn" class="btn btn-outline-success btn-lg">
                <i class="fas fa-download"></i>
                Tải Xuống Tất Cả Ảnh Chụp
              </button>
            </div>

            <!-- Account Info Screenshot -->
            <div class="card bg-dark border-secondary mb-4">
              <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                  <i class="fas fa-user"></i>
                  Thông Tin Tài Khoản
                </h5>
              </div>
              <div class="card-body text-center">
                <img id="infoScreenshot" class="img-fluid rounded shadow" alt="Thông Tin Tài Khoản" />
                <div class="mt-3">
                  <button class="btn btn-sm btn-outline-primary" onclick="downloadImage('infoScreenshot', 'account-info.png')">
                    <i class="fas fa-download"></i>
                    Tải Xuống
                  </button>
                </div>
              </div>
            </div>

            <!-- Inventory Screenshots -->
            <div class="card bg-dark border-secondary mb-4">
              <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">
                  <i class="fas fa-boxes"></i>
                  Ảnh Chụp Kho Đồ
                  <span id="batchCount" class="badge bg-secondary">0 lô</span>
                </h5>
              </div>
              <div class="card-body">
                <div id="inventoryScreenshots" class="row g-3">
                  <!-- Screenshots will be dynamically added here -->
                </div>
              </div>
            </div>

          </div>

        </div>
      </div>
    </div>
  </div>
</div>